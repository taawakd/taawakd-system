{
  "headers": [
    {
      "source": "/public/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ],
  "rewrites": [

    { "source": "/api/config.js", "destination": "/api/config.js" },
    { "source": "/api/analyze",   "destination": "/api/analyze.js" },
    { "source": "/api/admin",     "destination": "/api/admin.js" },

    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin\\.towkd\\.com" }],
      "destination": "/public/admin/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin\\.towkd\\.com" }],
      "destination": "/public/admin/$1"
    },

    {
      "source": "/",
      "has": [{ "type": "host", "value": "app\\.towkd\\.com" }],
      "destination": "/public/index.html"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app\\.towkd\\.com" }],
      "destination": "/public/$1"
    },

    { "source": "/auth",          "destination": "/public/auth.html" },
    { "source": "/auth.html",     "destination": "/public/auth.html" },
    { "source": "/login",         "destination": "/public/auth.html" },
    { "source": "/signup",        "destination": "/public/auth.html" },
    { "source": "/register",      "destination": "/public/auth.html" },

    { "source": "/",              "destination": "/public/landing.html" },
    { "source": "/(.*)",          "destination": "/public/$1" }

  ]
}
